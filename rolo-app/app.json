{
  "expo": {
    "name": "Rolo",
    "slug": "rolo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/rolo-logo.png",
    "userInterfaceStyle": "light",
    "scheme": "rolo",
    "splash": {
      "image": "./assets/rolo-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rolo.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Rolo needs camera access to scan business cards.",
        "NSPhotoLibraryUsageDescription": "Rolo needs photo library access to import business card images.",
        "NSContactsUsageDescription": "Rolo can import contacts from your address book."
      }
    },
    "android": {
      "package": "com.rolo.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/rolo-logo.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rolo needs photo library access to import business card images.",
          "cameraPermission": "Rolo needs camera access to scan business cards."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Rolo can import contacts from your address book."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "3ddc2c47-c0df-49b5-8ece-606c9b505192"
      }
    },
    "owner": "mpotter2002"
  }
}
